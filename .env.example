# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Tenant (used for featured tenant links + env fallback when DB unavailable)
# Production: resolve tenant from subdomain ({slug}.allbook.com.au or {slug}.localhost)
TENANT_SLUG=dayspa
NEXT_PUBLIC_TENANT_SLUG=dayspa
NEXT_PUBLIC_TENANT_DISPLAY_NAME=DaySpa
NEXT_PUBLIC_TENANT_TAGLINE=Premium day spa and massage bookings in Sydney.

# Web Push (PWA admin alerts) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@allbook.com.au
